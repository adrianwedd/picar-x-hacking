#!/usr/bin/env bash
# run-voice-loop-claude — launch the voice loop using Claude Code as the LLM backend.
#
# Usage:
#   bin/run-voice-loop-claude [--input-mode voice|text] [--dry-run] [--auto-log] [...]
#
# All extra arguments are forwarded to voice_loop.py (codex-voice-loop).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

# Point the voice loop at the claude bridge instead of the Codex CLI
export CODEX_CHAT_CMD="$SCRIPT_DIR/claude-voice-bridge"

exec "$SCRIPT_DIR/codex-voice-loop" \
    --prompt "$SCRIPT_DIR/../docs/prompts/claude-voice-system.md" \
    "$@"
