#!/usr/bin/env bash
# claude-voice-bridge — thin adapter so voice_loop can use Claude Code as its LLM backend.
#
# voice_loop pipes the full prompt (system instructions + state + user text) to stdin
# and expects a JSON action object on stdout.  This script:
#   1. Unsets CLAUDECODE so a nested `claude -p` invocation is permitted.
#   2. Reads stdin into a variable (prompt may be multi-KB but fits in RAM easily).
#   3. Calls `claude -p` with no shell tools and plain-text output format.
set -euo pipefail

# Guard: claude must be on PATH
if ! command -v claude >/dev/null 2>&1; then
    echo '{"error": "claude not found on PATH"}' >&2
    exit 1
fi

# Allow nested claude invocation from within a Claude Code session
unset CLAUDECODE CLAUDE_CODE_ENTRYPOINT 2>/dev/null || true

# Read the full prompt from stdin
PROMPT=$(cat)

if [ -z "$PROMPT" ]; then
    echo '{"error": "empty prompt received"}' >&2
    exit 1
fi

# Run Claude in non-interactive mode:
#   --system-prompt          → replaces the default Claude Code coding-assistant prompt
#   --allowedTools ""        → no shell/file tools; Claude outputs JSON only
#   --output-format text     → plain text stdout (not stream-json)
#   --no-session-persistence → each turn is stateless (state lives in session.json)
exec claude -p "$PROMPT" \
    --system-prompt "You are a robot assistant controller. The user message contains your full instructions. Follow them exactly. Output ONLY a JSON object as a plain text string — do not use any tool_use API features, do not call any tools, do not include markdown fences. Just output the raw JSON object." \
    --allowedTools "" \
    --output-format text \
    --no-session-persistence
