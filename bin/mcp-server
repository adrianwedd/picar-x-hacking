#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"
# Use project venv python, falling back to PATH python3.
# The project venv may contain a cross-arch binary (Pi ARM venv checked out
# on Mac), so verify it can actually execute before using it.
PY="$PROJECT_ROOT/.venv/bin/python3"
if [ -x "$PY" ] && "$PY" -c "pass" 2>/dev/null; then
    exec "$PY" -m pxh.mcp_server "$@"
else
    exec python3 -m pxh.mcp_server "$@"
fi
