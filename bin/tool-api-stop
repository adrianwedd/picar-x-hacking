#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: stop the API server daemon."""
from __future__ import annotations

import json
import os
import signal
import time
from pathlib import Path

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
LOG_DIR      = Path(os.environ.get("LOG_DIR", PROJECT_ROOT / "logs"))
PID_FILE     = LOG_DIR / "px-api-server.pid"


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "0") != "0"

    if not PID_FILE.exists():
        payload = {"status": "not_running"}
        log_event("api-stop", payload)
        print(json.dumps(payload))
        return 0

    try:
        pid = int(PID_FILE.read_text().strip())
    except (ValueError, OSError):
        PID_FILE.unlink(missing_ok=True)
        payload = {"status": "error", "error": "corrupt PID file; removed"}
        log_event("api-stop", payload)
        print(json.dumps(payload))
        return 1

    if dry_mode:
        payload = {"status": "ok", "dry": True, "message": f"would stop PID {pid}"}
        log_event("api-stop", payload)
        print(json.dumps(payload))
        return 0

    try:
        os.kill(pid, signal.SIGTERM)
        # Wait briefly for clean shutdown
        for _ in range(10):
            time.sleep(0.5)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                break
    except ProcessLookupError:
        pass  # already dead

    PID_FILE.unlink(missing_ok=True)

    update_session(
        fields={"last_action": "tool_api_stop"},
        history_entry={"event": "api_stop", "pid": pid, "dry": False},
    )

    payload = {"status": "ok", "pid": pid, "stopped": True}
    log_event("api-stop", payload)
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
