#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: sweep sonar, then point camera toward closest object."""
from __future__ import annotations

import json
import os
import subprocess
from pathlib import Path

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
TOOL_SONAR   = PROJECT_ROOT / "bin" / "tool-sonar"
TOOL_LOOK    = PROJECT_ROOT / "bin" / "tool-look"


def run_tool(path: Path, extra_env: dict) -> dict:
    env = os.environ.copy()
    env.update(extra_env)
    result = subprocess.run(
        [str(path)],
        capture_output=True,
        text=True,
        check=False,
        env=env,
    )
    try:
        return json.loads(result.stdout.strip().splitlines()[-1])
    except (json.JSONDecodeError, IndexError):
        return {"status": "error", "returncode": result.returncode, "stderr": result.stderr[-256:]}


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "1") != "0"

    if dry_mode:
        angle = 0
        payload = {"status": "ok", "angle": angle, "closest_cm": -1, "dry": True}
        log_event("face", payload)
        update_session(
            fields={"last_action": "tool_face"},
            history_entry={"event": "face", "angle": angle, "dry": True},
        )
        print(json.dumps(payload))
        return 0

    # Step 1: sonar sweep to find closest object angle
    try:
        sonar_result = run_tool(TOOL_SONAR, {})
    except Exception as exc:
        payload = {"status": "error", "error": f"sonar failed: {exc}"}
        log_event("face", payload)
        print(json.dumps(payload))
        return 1

    if sonar_result.get("status") != "ok":
        payload = {
            "status": "error",
            "error": "sonar returned error",
            "sonar": sonar_result,
        }
        log_event("face", payload)
        print(json.dumps(payload))
        return 1

    closest_angle = sonar_result.get("closest_angle", 0)
    closest_cm    = sonar_result.get("closest_cm", -1)

    # Step 2: point camera toward closest angle
    try:
        look_result = run_tool(TOOL_LOOK, {
            "PX_PAN":  str(int(closest_angle)),
            "PX_TILT": "0",
            "PX_EASE": "0.50",
        })
    except Exception as exc:
        payload = {"status": "error", "error": f"look failed: {exc}"}
        log_event("face", payload)
        print(json.dumps(payload))
        return 1

    payload = {
        "status": "ok",
        "angle": closest_angle,
        "closest_cm": closest_cm,
        "dry": False,
        "look": look_result,
    }
    log_event("face", payload)
    update_session(
        fields={"last_action": "tool_face"},
        history_entry={"event": "face", "angle": closest_angle, "closest_cm": closest_cm, "dry": False},
    )
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
