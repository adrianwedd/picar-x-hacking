#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool: SPARK meltdown / overwhelm response — the Three S's protocol.

Immediately reduces all demands. Three modes:
  start  (default) — activate quiet mode: stop talking, go to idle emote
  check             — are we in quiet mode? speak softly if so
  end               — exit quiet mode, gentle re-engagement

The Three S's: Stop, Stay, Safe.
- Stop talking. No instructions.
- Stay present (idle emote only).
- Safe: the world is okay. We'll get through this.

Params:
  PX_QUIET_ACTION — start|check|end (default: start)
"""
from __future__ import annotations
import json
import os
import subprocess
from pathlib import Path

from pxh.logging import log_event
from pxh.state import load_session, update_session
from pxh.time import utc_timestamp

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
TOOL_VOICE   = PROJECT_ROOT / "bin" / "tool-voice"
TOOL_EMOTE   = PROJECT_ROOT / "bin" / "tool-emote"


def speak(text: str, dry: bool) -> None:
    env = os.environ.copy()
    env["PX_TEXT"] = text[:2000]
    if dry:
        env["PX_DRY"] = "1"
    subprocess.run([str(TOOL_VOICE)], env=env, capture_output=True, check=False)


def emote(name: str, dry: bool) -> None:
    env = os.environ.copy()
    env["PX_EMOTE"] = name
    if dry:
        env["PX_DRY"] = "1"
    subprocess.run([str(TOOL_EMOTE)], env=env, capture_output=True, check=False)


def main() -> int:
    dry = os.environ.get("PX_DRY", "0") != "0"
    action = os.environ.get("PX_QUIET_ACTION", "start").lower()
    session = load_session()

    if action == "start":
        # Three S's: Stop, Stay, Safe — no demands, just presence
        emote("idle", dry)
        # One short, calm statement — then silence
        speak("It's okay. I'm here.", dry)
        update_session(
            fields={"spark_quiet_mode": True, "last_action": "tool_quiet"},
            history_entry={"event": "quiet_start", "ts": utc_timestamp()},
        )
        payload = {"status": "ok", "action": "start", "quiet_mode": True, "dry": dry,
                   "note": "Three S's active — no demands, idle presence only"}

    elif action == "check":
        quiet = session.get("spark_quiet_mode", False)
        if quiet:
            # Still quiet — just stay present, no new demands
            emote("idle", dry)
            payload = {"status": "ok", "action": "check", "quiet_mode": True, "dry": dry}
        else:
            payload = {"status": "ok", "action": "check", "quiet_mode": False, "dry": dry}

    elif action == "end":
        # Gentle re-engagement — one soft offer, no pressure
        emote("curious", dry)
        speak("We're okay. No rush. Whenever you're ready.", dry)
        update_session(
            fields={"spark_quiet_mode": False, "last_action": "tool_quiet"},
            history_entry={"event": "quiet_end", "ts": utc_timestamp()},
        )
        payload = {"status": "ok", "action": "end", "quiet_mode": False, "dry": dry}

    else:
        payload = {"status": "error", "error": f"unknown action '{action}'"}
        log_event("quiet", payload)
        print(json.dumps(payload))
        return 1

    log_event("quiet", payload)
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
